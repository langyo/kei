# kei — environment configuration
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# The justfile auto-loads .env (via `set dotenv-load`). Values here override
# the defaults baked into the justfile but are themselves overridden by
# real environment variables exported in your shell.

# ── aris rendering engine ────────────────────────────────────
#
# Path to the aris repository (https://github.com/celestia-island/aris).
# kei compiles aris's kei_desktop / kei_ui binaries (musl cross-compile) and
# packages them into the desktop initramfs. This can be:
#   - A relative path from the kei root (e.g. ../aris)
#   - An absolute Windows path   (e.g. D:\source\aris)
#   - An absolute POSIX path     (e.g. /mnt/d/source/aris or /home/user/aris)
#
# Default if unset: ../aris (sibling directory layout)
ARIS_REPO=../aris
